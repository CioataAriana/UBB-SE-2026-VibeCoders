<Page
    x:Class="MovieMarketplace.Views.MyOrdersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MovieMarketplace.Models">

    <Grid Padding="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,30">
            <Button x:ConnectionId='10' Content="" FontFamily="Segoe MDL2 Assets"                    Background="Transparent" FontSize="20"/>
            <TextBlock Text="My Purchase History" FontSize="32" FontWeight="Bold"/>
        </StackPanel>

        <ListView x:ConnectionId='2' Grid.Row="1" x:Name="OrdersList" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate                                    >
                    <Border x:ConnectionId='4' Background="#2A2A2A" Margin="0,0,0,10" Padding="15" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock x:ConnectionId='6'                                FontSize="20" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:ConnectionId='7'                        Foreground="#4CAF50" FontWeight="SemiBold"/>
                                <TextBlock x:ConnectionId='8'                                 FontSize="12" Foreground="Gray"/>
                                <TextBlock x:ConnectionId='9'                        FontSize="14" FontWeight="Bold" Foreground="Orange"/>
                            </StackPanel>

                            <Button x:ConnectionId='5' Grid.Column="1" 
                                    x:Name="ConfirmBtn"
                                    Content="Confirm Received" 
                                    VerticalAlignment="Center"
                                    Background="DarkBlue" Foreground="White"
                                                                                          
                                                                 
                                                     />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

