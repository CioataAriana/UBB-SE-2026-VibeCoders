<Page x:ConnectionId='1'
    x:Class="MovieMarketplace.Views.SellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="40" Spacing="15" MaxWidth="500" HorizontalAlignment="Left">

            <TextBlock Text="Sell Your Equipment" FontSize="28" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBox x:ConnectionId='2' x:Name="TitleInput" Header="Equipment Title" PlaceholderText="e.g. Sony A7 III"
                                                                        />

            <ComboBox x:ConnectionId='3' x:Name="CategoryInput" Header="Category" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Cameras"/>
                <ComboBoxItem Content="Microphones"/>
                <ComboBoxItem Content="Lighting"/>
                <ComboBoxItem Content="Accessories"/>
            </ComboBox>

            <ComboBox x:ConnectionId='4' x:Name="ConditionInput" Header="Condition" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="New"/>
                <ComboBoxItem Content="Used - Like New"/>
                <ComboBoxItem Content="Used - Good"/>
            </ComboBox>

            <TextBox x:ConnectionId='5' x:Name="DescriptionInput" Header="Description" PlaceholderText="Tell us about the condition..."
                     AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                                                                       />

            <TextBox x:ConnectionId='6' x:Name="PriceInput" Header="Price ($)" PlaceholderText="e.g. 1500"
                                                                        />

            <TextBlock Text="Equipment Photo" FontWeight="SemiBold" FontSize="14" Margin="0,5,0,0"/>

            <Grid x:ConnectionId='7' x:Name="ImageUploadContainer" Height="120"                                                       >
                <Rectangle Stroke="Gray" StrokeThickness="2" StrokeDashArray="4,2" RadiusX="8" RadiusY="8" Fill="#1A1A1A"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="5">
                    <FontIcon Glyph="&#xEB9F;" FontSize="32" Foreground="Gray"/>
                    <TextBlock x:ConnectionId='12' x:Name="FileNameLabel" Text="Click to select gear photo" Foreground="Gray" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <TextBox x:ConnectionId='8' x:Name="ImageUrlInput" Header="Or Image URL" PlaceholderText="Paste link here..."/>

            <TextBlock x:ConnectionId='9' x:Name="ValidationErrorText" Text="Please fill in all fields before submitting!" 
                       Foreground="Red" FontWeight="SemiBold" Visibility="Collapsed"/>

            <Button x:ConnectionId='10' Content="Submit Listing"                            
                    Style="{StaticResource AccentButtonStyle}" Margin="0,10,0,0" HorizontalAlignment="Stretch"/>

            <Button x:ConnectionId='11' Content="Back to Menu"                          HorizontalAlignment="Stretch"/>

        </StackPanel>
    </ScrollViewer>
</Page>

