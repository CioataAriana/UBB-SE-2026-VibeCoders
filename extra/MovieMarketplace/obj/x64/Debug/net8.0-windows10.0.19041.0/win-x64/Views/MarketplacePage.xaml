<Page x:ConnectionId='1'
    x:Class="MovieMarketplace.Views.MarketplacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MovieMarketplace.Models"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="0,0,0,20">
            <Button x:ConnectionId='11' Content="" FontFamily="Segoe MDL2 Assets"                           Background="Transparent"/>
            <TextBlock Text="Available Equipment" FontSize="28" FontWeight="Bold"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="15" Margin="0,0,0,20">
            <TextBlock Text="Filter:" VerticalAlignment="Center"/>
            <ComboBox x:ConnectionId='10' x:Name="CategoryFilter" Width="200"                                                   >
                <ComboBoxItem Content="All"/>
                <ComboBoxItem Content="Cameras"/>
                <ComboBoxItem Content="Microphones"/>
                <ComboBoxItem Content="Lighting"/>
                <ComboBoxItem Content="Accessories"/>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:ConnectionId='2'                                                             >
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate                              >
                        <Border x:ConnectionId='4' Background="#212121" 
                        CornerRadius="12" 
                        Margin="10" 
                        Width="240" 
                        Height="340" 
                        BorderBrush="#333333" 
                        BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Border CornerRadius="12,12,0,0" Height="180" Background="#1A1A1A">
                                    <Image x:ConnectionId='9'                            Stretch="UniformToFill" />
                                </Border>

                                <StackPanel Padding="15" Spacing="5">
                                    <TextBlock x:ConnectionId='5'                       
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       MaxLines="1" 
                                       TextTrimming="CharacterEllipsis"/>

                                    <TextBlock x:ConnectionId='6'                          
                                       FontSize="12" 
                                       Foreground="Gray"/>

                                    <TextBlock x:ConnectionId='7'                       
                                       FontSize="22" 
                                       FontWeight="Bold" 
                                       Foreground="#4CAF50" 
                                       Margin="0,5,0,5"/>

                                    <Button x:ConnectionId='8' Content="VIEW DETAILS" 
                                                            
                                    HorizontalAlignment="Stretch" 
                                    Background="DarkGreen" 
                                    Foreground="White"
                                    CornerRadius="6"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>

