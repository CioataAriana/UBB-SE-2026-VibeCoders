<Page
    x:Class="MovieMarketplace.Views.MySalesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MovieMarketplace.Models">

    <Grid Padding="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,30">
            <Button x:ConnectionId='10' Content="" FontFamily="Segoe MDL2 Assets"                    Background="Transparent" FontSize="20"/>
            <TextBlock Text="Sales &amp; Notifications" FontSize="32" FontWeight="Bold"/>
        </StackPanel>

        <ListView x:ConnectionId='2' Grid.Row="1" x:Name="SalesList" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate                                    >
                    <Border x:ConnectionId='4' Background="#212121" BorderBrush="DarkRed" BorderThickness="1,1,1,4" Margin="0,0,0,15" Padding="20" CornerRadius="4">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" Foreground="Orange" VerticalAlignment="Center"/>
                                <TextBlock Text="ITEM SOLD!" FontSize="18" FontWeight="ExtraBold" Foreground="Orange"/>
                            </StackPanel>

                            <TextBlock FontSize="16" TextWrapping="Wrap">
                                <Run Text="Your item "/>
                                <Run x:ConnectionId='8'                                FontWeight="Bold" Foreground="White"/>
                                <Run Text=" was purchased for "/>
                                <Run x:ConnectionId='9'                        Foreground="LightGreen" FontWeight="Bold"/>
                                <Run Text="."/>
                            </TextBlock>

                            <Border Background="#2D2D2D" Padding="10" CornerRadius="4">
                                <StackPanel>
                                    <TextBlock Text="SHIPPING INSTRUCTIONS:" FontSize="12" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,5"/>
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="Please send the product to the following address: "/>
                                        <Run x:ConnectionId='7'                                 FontWeight="SemiBold" Foreground="SkyBlue"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock FontSize="12" Foreground="Gray">
                                <Run Text="Status: "/>
                                <Run x:ConnectionId='5'                        FontWeight="Bold"/>
                                <Run Text=" | Date: "/>
                                <Run x:ConnectionId='6'                                />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

