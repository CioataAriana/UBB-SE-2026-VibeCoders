<UserControl
    x:Class="MovieShop.Views.MovieShopView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:models="using:MovieShop.Models"
    xmlns:local="using:MovieShop.Views">
    <Grid Background="#1E1E1E" Padding="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <local:FlashSaleBanner Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="20" Margin="0,0,20,0">
            <TextBlock Text="Search by title" FontSize="14" Foreground="Gray"/>
            <TextBox PlaceholderText="Search..." x:Name="SearchBox"/>

            <TextBlock Text="Filter" FontSize="18" FontWeight="Bold" Margin="0,10,0,5"/>
            <StackPanel Spacing="5">
                <RadioButton Content="Ascending price" GroupName="Sort"/>
                <RadioButton Content="Descending price" GroupName="Sort"/>
                <RadioButton Content="Highest rating" GroupName="Sort"/>
                <RadioButton Content="Lowest rating" GroupName="Sort"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</UserControl>