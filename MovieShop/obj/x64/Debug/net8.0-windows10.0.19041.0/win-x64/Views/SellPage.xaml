<Page x:ConnectionId='1'
    x:Class="MovieShop.Views.SellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="40" Spacing="20" MaxWidth="600" HorizontalAlignment="Center">

                <TextBlock Text="List Your Gear" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>

                <TextBox x:ConnectionId='2' x:Name="TitleInput" Header="Equipment Title" 
                                                                             Foreground="White"/>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:ConnectionId='11' x:Name="CategoryInput" Header="Category" HorizontalAlignment="Stretch" Grid.Column="0">
                        <ComboBoxItem Content="Cameras" IsSelected="True"/>
                        <ComboBoxItem Content="Microphones"/>
                        <ComboBoxItem Content="Lighting"/>
                        <ComboBoxItem Content="Accessories"/>
                    </ComboBox>
                    <ComboBox x:ConnectionId='12' x:Name="ConditionInput" Header="Condition" HorizontalAlignment="Stretch" Grid.Column="1">
                        <ComboBoxItem Content="New" IsSelected="True"/>
                        <ComboBoxItem Content="Used - Like New"/>
                        <ComboBoxItem Content="Used - Good"/>
                    </ComboBox>
                </Grid>

                <TextBox x:ConnectionId='3' x:Name="DescriptionInput" Header="Description" AcceptsReturn="True" Height="100" 
                         TextWrapping="Wrap"                                                   />

                <StackPanel Spacing="5">
                    <TextBox x:ConnectionId='9' x:Name="PriceInput" Header="Price ($)" 
                                                                              />
                    <TextBlock x:ConnectionId='10'                                                          
                               Foreground="#FF5252" FontSize="12" MinHeight="16"/>
                </StackPanel>

                <TextBlock Text="Equipment Photo" FontWeight="SemiBold" FontSize="14" Foreground="White"/>
                <Grid x:ConnectionId='4' x:Name="ImageUploadContainer" Height="120"                                                       >
                    <Rectangle Stroke="Gray" StrokeThickness="2" StrokeDashArray="4,2" RadiusX="8" RadiusY="8" Fill="#1A1A1A"/>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="5">
                        <FontIcon Glyph="&#xEB9F;" FontSize="32" Foreground="Gray"/>
                        <TextBlock x:ConnectionId='8' x:Name="FileNameLabel" Text="Click to select gear photo" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <TextBox x:ConnectionId='5' x:Name="ImageUrlInput" Header="Or Image URL" PlaceholderText="Paste link here..." Foreground="White"/>

                <StackPanel Spacing="10" Margin="0,20,0,0">
                    <Button x:ConnectionId='6' Content="SUBMIT LISTING"                            
                                                                               
                            Background="DarkGreen" Foreground="White" HorizontalAlignment="Stretch" Height="50" FontWeight="Bold"/>
                    <Button x:ConnectionId='7' Content="CANCEL / BACK"                          
                            Background="Transparent" BorderBrush="Gray" BorderThickness="1" HorizontalAlignment="Stretch" Height="40"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

