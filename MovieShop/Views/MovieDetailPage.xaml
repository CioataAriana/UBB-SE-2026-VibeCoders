<Page
    x:Class="MovieShop.Views.MovieDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <Grid Padding="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="BackToCatalogButton"
                    Content="Back to catalog"
                    Click="BackToCatalog_Click"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Foreground="#9E9E9E"
                    BorderThickness="0"
                    Padding="0,0,0,12"
                    Grid.Row="0"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="12" Margin="0,0,20,0" BorderBrush="#333" BorderThickness="1">
                    <Image x:Name="PosterImage" Stretch="Uniform" MaxWidth="520" Margin="20"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="14" Margin="12,0,0,0">
                    <TextBlock x:Name="TitleLabel" FontSize="40" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>

                    <TextBlock x:Name="RatingLabel" FontSize="20" Foreground="#FFC107"/>

                    <TextBlock x:Name="DescriptionLabel" FontSize="17" Foreground="#BDBDBD" TextWrapping="Wrap"/>

                    <TextBlock x:Name="PriceLabel" FontSize="34" Foreground="#4CAF50" FontWeight="Bold" Margin="0,8,0,0"/>

                    <Button x:Name="BuyMovieButton"
                            Content="Buy Movie"
                            Click="BuyMovieButton_Click"
                            Width="280"
                            Height="52"
                            FontSize="18"
                            FontWeight="Bold"
                            Background="#1DB954"
                            Foreground="White"
                            CornerRadius="8"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0"/>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <Button x:Name="ReviewsButton"
                                Click="ReviewsButton_Click"
                                MinWidth="200"
                                Height="44"/>
                        <Button x:Name="EventsButton"
                                Content="See related upcoming events"
                                Click="EventsButton_Click"
                                MinWidth="260"
                                Height="44"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
