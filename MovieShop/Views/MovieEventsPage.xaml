<Page
    x:Class="MovieShop.Views.MovieEventsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E" Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="Back to Purchase"
                Click="BackToPurchase_Click"
                HorizontalAlignment="Left"
                Background="#333"
                Foreground="White"
                Padding="16,10"
                CornerRadius="6"
                Margin="0,0,0,16"/>

        <TextBlock x:Name="HeaderText"
                   Grid.Row="1"
                   Text="Upcoming events"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EventsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2A2A2A" CornerRadius="10" Margin="0,0,0,14" BorderBrush="#444" BorderThickness="1" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="10,0,0,10" Margin="0,0,16,0">
                                    <Image Source="{Binding PosterSource}" Stretch="UniformToFill" Height="160"/>
                                </Border>
                                <StackPanel Grid.Column="1" Padding="0,12,16,12" Spacing="6">
                                    <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding WhenWhere}" Foreground="#9E9E9E" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#BDBDBD" TextWrapping="Wrap" MaxLines="3"/>
                                    <TextBlock Text="{Binding PriceLine}" Foreground="#4CAF50" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
