<Page
    x:Class="MovieShop.Views.MovieReviewsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E" Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="Back to Purchase"
                Click="BackToPurchase_Click"
                HorizontalAlignment="Left"
                Background="#333"
                Foreground="White"
                Padding="16,10"
                CornerRadius="6"
                Margin="0,0,0,16"/>

        <TextBlock x:Name="HeaderText"
                   Grid.Row="1"
                   Text="Reviews"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="White"
                   Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ReviewsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2A2A2A" CornerRadius="10" Padding="16" Margin="0,0,0,12" BorderBrush="#444" BorderThickness="1">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding UserDisplayName}" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Foreground="#FFC107">
                                    <Run Text="★ "/>
                                    <Run Text="{Binding StarRating}"/>
                                    <Run Text="/5"/>
                                </TextBlock>
                                <TextBlock Text="{Binding CommentLine}" Foreground="#CCC" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding CreatedAtDisplay}" Foreground="#888" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
