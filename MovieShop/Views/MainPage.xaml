<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MovieShop.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="BigSaleBanner" 
            Grid.Row="0"
            Background="#D32F2F" 
            Padding="40" 
            HorizontalAlignment="Stretch" 
            Visibility="{x:Bind FlashSaleVM.BannerVisibility, Mode=OneWay}">

            <StackPanel Spacing="15" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind FlashSaleVM.DisplayText}" FontSize="48" Foreground="White" HorizontalAlignment="Center"/>

                <TextBlock x:Name="BigTimerText" Text="{x:Bind FlashSaleVM.TimerText, Mode=OneWay}" FontSize="36" 
                       Foreground="White" HorizontalAlignment="Center" FontWeight="Bold"/>

                <Button x:Name="DiscoverButton" 
                    Content="discover our discounted movies!" 
                    Click="DiscoverButton_Click"
                    HorizontalAlignment="Center" 
                    Background="#B71C1C" Foreground="White" Padding="20,10"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="20" Spacing="10">
            <TextBlock Text="(Movies that are not on sale)" Foreground="Gray"/>
        </StackPanel>
    </Grid>
</UserControl>
